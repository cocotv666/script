-- Load the notification module
local NotificationHolder = loadstring(game:HttpGet("https://raw.githubusercontent.com/BocusLuke/UI/main/STX/Module.Lua"))()
local Notification = loadstring(game:HttpGet("https://raw.githubusercontent.com/BocusLuke/UI/main/STX/Client.Lua"))()

-- Function to display messages and play sound
local function showMessage(player)
    Notification:Notify(
        {Title = "Staff Detector", Description = "Staff " .. player.Name .. " Has Joined The Game !!! Staff ID: " .. player.UserId},
        {OutlineColor = Color3.fromRGB(80, 80, 80), Time = 5, Type = "default"}
    )

    -- Play a sound
    local sound = Instance.new("Sound", workspace)
    sound.Name = "Noooooooooooooooot"
    sound.SoundId = "rbxassetid://9119799686"
    sound:Play()
end

-- IDs of multiple players to detect
local targetIDs = {
    22808138,
    1502104539,
    1651271585,
    307212658,
    2428373515,
    426378541,
    1049767300,
    184655415,
    288323165,
    514679433
}

-- Display a notification indicating that the detector is active
Notification:Notify(
    {Title = "Staff Detector", Description = "Staff Detector By coco"},
    {OutlineColor = Color3.fromRGB(80, 80, 80), Time = 5, Type = "default"}
)

-- Continuous loop to check all players
while true do
    for _, player in pairs(game.Players:GetPlayers()) do
        for _, targetID in ipairs(targetIDs) do
            if player.UserId == targetID then
                showMessage(player)
            end
        end
    end
    wait(1) -- Wait for a while before checking again to avoid significant performance impact
end
