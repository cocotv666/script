local UserInputService = game:GetService("UserInputService")

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui

local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.new(8, 0, 0)
Frame.Position = UDim2.new(0, 0, 0.3, 0)
Frame.Size = UDim2.new(0.1, 0, 0.2)
Frame.Active = true
Frame.Draggable = true

local function CreateButton(text, positionY)
    local Button = Instance.new("TextButton")
    Button.Parent = Frame
    Button.BackgroundColor3 = Color3.new(5, 5, 5)
    Button.Position = UDim2.new(0.1, 0, positionY, 0)
    Button.Size = UDim2.new(0.8, 0, 0.2, 0)
    Button.Font = Enum.Font.SourceSansLight
    Button.FontSize = Enum.FontSize.Size14
    Button.Text = text
    Button.TextScaled = true
    Button.TextSize = 8
    Button.TextWrapped = true
    return Button
end

local TextButton = CreateButton("Fly (KeyCode:X)", 0.1)
local UpButton = CreateButton("Up", 0.4)
local DownButton = CreateButton("Down", 0.7)

local FlyBodyVelocity
local FlyDown = false
local FlyUp = false

local function ToggleFly()
    if FlyBodyVelocity then
        FlyBodyVelocity:Destroy()
        FlyBodyVelocity = nil
        FlyDown = false
        FlyUp = false
        game.Workspace.Gravity = 196.2
        return
    end

    FlyBodyVelocity = Instance.new("BodyVelocity")
    FlyBodyVelocity.MaxForce = Vector3.new(0, 9e9, 0)
    FlyBodyVelocity.Name = "FlyBodyVelocity"
    FlyBodyVelocity.Parent = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    FlyDown = false
    FlyUp = false
    game.Workspace.Gravity = 0
end

local function FlyUpFunction()
    FlyUp = true
end

local function FlyDownFunction()
    FlyDown = true
end

local function FlyUpEndFunction()
    FlyUp = false
end

local function FlyDownEndFunction()
    FlyDown = false
end

TextButton.MouseButton1Click:Connect(ToggleFly)
UpButton.MouseButton1Down:Connect(FlyUpFunction)
UpButton.MouseButton1Up:Connect(FlyUpEndFunction)
DownButton.MouseButton1Down:Connect(FlyDownFunction)
DownButton.MouseButton1Up:Connect(FlyDownEndFunction)

while true do
    wait()

    if FlyBodyVelocity then
        FlyBodyVelocity.Velocity = Vector3.new(0, (FlyUp and 40 or 0) + (FlyDown and -40 or 0), 0)
    end
end
